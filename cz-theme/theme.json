{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "settings": {

    "spacing": {
        "spacingScale": {
            "steps": 0
        },
        "spacingSizes": [
            {
                "name": "Page margin",
                "slug": "page-margin",
                "size": "6rem"
            }
        ]
    },

    "appearanceTools": true,

    "layout": {
      "contentSize": "1200px",
      "wideSize": "1400px"
    },

    "typography": {
      "dropCap": false,
      "fontFamilies": [
        {
          "fontFace": [
            {
              "fontFamily": "Prompt",
              "fontWeight": "400",
              "src": [
                "file:./assets/fonts/prompt/Prompt-Regular.ttf"
              ]
            },
            {
              "fontFamily": "Prompt",
              "fontWeight": "700",
              "src": [
                "file:./assets/fonts/prompt/Prompt-Bold.ttf"
              ]
            },
            {
              "fontFamily": "Prompt",
              "fontWeight": "300",
              "src": [
                "file:./assets/fonts/prompt/Prompt-Light.ttf"
              ]
            }
          ],
          "fontFamily": "Prompt, sans-serif",
          "name": "Prompt",
          "slug": "prompt"
        },
        {
          "fontFace": [
            {
              "fontFamily": "Roboto",
              "fontWeight": "400",
              "src": [
                "file:./assets/fonts/roboto/Roboto-VariableFont_wdth,wght.ttf"
              ]
            }
          ],
          "fontFamily": "Roboto, sans-serif",
          "name": "Roboto",
          "slug": "roboto"
        }
      ],

      "fontSizes": [
        {
          "name": "Small",
          "slug": "small",
          "size": "13px"
        },
        {
          "name": "Medium",
          "slug": "medium",
          "size": "20px"
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "36px"
        },
        {
          "name": "Extra Large",
          "slug": "x-large",
          "size": "42px"
        }
      ]
    },

    "blocks": {
      "core/cover": {
        "color": {
          "custom": true
        }
      }
    }
  },

  "templateParts": [
    {
      "area": "header",
      "name": "header",
      "title": "Header"
    },
    {
      "area": "footer",
      "name": "footer",
      "title": "Footer"
    }
  ],

  "styles": {

    "typography": {
      "fontFamily": "var(--wp--preset--font-family--prompt)",
      "fontSize": "18px",
      "fontWeight": "300"
    },

    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--prompt)",
          "fontWeight": "300"
        }
      },
      "h1": {
        "typography": { "fontWeight": "300" }
      },
      "h2": {
        "typography": { "fontWeight": "300" }
      },
      "h3": {
        "typography": { "fontWeight": "300" }
      }
    },

    "blocks": {
      "core/site-title": {
        "elements": {
          "link": {
            "typography": {
              "textDecoration": "none",
              "fontFamily": "var(--wp--preset--font-family--prompt)",
              "fontWeight": "300",
              "fontSize": "56px"
            }
          }
        }
      }
    }
  }
}
